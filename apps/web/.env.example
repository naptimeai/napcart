NEXT_PUBLIC_APP_NAME=NapCart
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_NAPCART_DEPLOYMENT_MODE=core
NEXT_PUBLIC_DEFAULT_RESTAURANT_SLUG=
NEXT_PUBLIC_CLIENT_NAME=NapCart
NEXT_PUBLIC_CLIENT_DESCRIPTION="Restaurant ordering, catalog, branch, delivery, and WhatsApp operations dashboard."
NEXT_PUBLIC_CLIENT_ICON_PATH=
NEXT_PUBLIC_CLIENT_WEBSITE_URL=
NEXT_PUBLIC_DEFAULT_COUNTRY=PK
NEXT_PUBLIC_DEFAULT_CURRENCY=PKR
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Karachi

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-project-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-project-service-role-key

DATABASE_URL=replace-with-database-url

WHATSAPP_PROVIDER=mock
WHATSAPP_MOCK_ACTION_SECRET=replace-with-local-mock-action-secret

# Phase 6A: Meta WhatsApp Cloud API provider-ready configuration.
# Keep live credentials empty until a real restaurant/client connects Meta.
WHATSAPP_META_WEBHOOK_VERIFY_TOKEN=replace-with-meta-webhook-verify-token
WHATSAPP_META_APP_SECRET=replace-with-meta-app-secret
WHATSAPP_META_ACTION_SECRET=replace-with-meta-action-signing-secret
# Local-only escape hatch for mocked webhook payload tests. Keep false for Preview/Production.
WHATSAPP_META_ALLOW_UNSIGNED_WEBHOOKS=false
WHATSAPP_META_API_BASE_URL=https://graph.facebook.com
WHATSAPP_META_GRAPH_API_VERSION=v23.0
